{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "green_deepseek_api_key": {
        "type": "string",
        "secret": true
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "purple1_agent_llm": {
        "type": "string"
      },
      "purple1_deepseek_api_key": {
        "type": "string",
        "secret": true
      },
      "purple1_gemini_api_key": {
        "type": "string",
        "secret": true
      },
      "purple1_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "purple1_agent_llm"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/heads/main/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "user_llm": "gemini/gemini-3-pro-preview",
          "max_steps": 200
        },
        "participant_roles": {
          "green": "green",
          "purple1": "purple1"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "deepseek_api_key": "${config.green_deepseek_api_key}",
        "gemini_api_key": "${config.green_gemini_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "purple1": {
      "manifest": "https://raw.githubusercontent.com/Andrew7234/tau2-agentbeats-base-purple/refs/heads/main/amber-manifest.json5",
      "config": {
        "agent_llm": "${config.purple1_agent_llm}",
        "deepseek_api_key": "${config.purple1_deepseek_api_key}",
        "gemini_api_key": "${config.purple1_gemini_api_key}",
        "openai_api_key": "${config.purple1_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#purple1.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#purple1.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cd9b2-331c-77b3-8535-e5b31a2701a7",
      "purple1": "019cd992-3f47-7a41-8d90-0088d767ed10"
    }
  }
}
{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_agent_llm": {
        "type": "string"
      },
      "agent_agent_max_output_tokens": {
        "type": "integer",
        "default": 600
      },
      "agent_agent_reasoning_effort": {
        "type": "string",
        "default": ""
      },
      "agent_agent_temperature": {
        "type": "number",
        "default": 0.2
      },
      "agent_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "agent_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "agent_openai_api_base": {
        "type": "string",
        "default": ""
      },
      "agent_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": [
      "agent_agent_llm"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "max_steps": 200,
          "num_tasks": 1
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "deepseek_api_key": "${config.green_deepseek_api_key}",
        "gemini_api_key": "${config.green_gemini_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/VlaTz/tau2-agentbeats-base-purple/refs/heads/main/amber-manifest.json5",
      "config": {
        "agent_llm": "${config.agent_agent_llm}",
        "agent_max_output_tokens": "${config.agent_agent_max_output_tokens}",
        "agent_reasoning_effort": "${config.agent_agent_reasoning_effort}",
        "agent_temperature": "${config.agent_agent_temperature}",
        "deepseek_api_key": "${config.agent_deepseek_api_key}",
        "gemini_api_key": "${config.agent_gemini_api_key}",
        "openai_api_base": "${config.agent_openai_api_base}",
        "openai_api_key": "${config.agent_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cf80f-8938-79c0-a221-4c7eadd43e7e",
      "agent": "019d4537-6e9b-7442-85e7-e60476821f01"
    }
  }
}
{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_anthropic_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "user_llm": "anthropic/claude-3-5-sonnet-20241022",
          "max_steps": 200
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "anthropic_api_key": "${config.agent_anthropic_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/Keer0205/tau2-purple-agent/refs/heads/main/amber-manifest.json5",
      "config": {
        "anthropic_api_key": "${config.agent_anthropic_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cf80f-8938-79c0-a221-4c7eadd43e7e",
      "agent": "019d3ffd-8046-7a10-8845-36cbc906a829"
    }
  }
}

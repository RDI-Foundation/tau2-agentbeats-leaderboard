{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_osin_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_osin_tau2_agent_llm": {
        "type": "string"
      },
      "agent_osin_tau2_agent_temperature": {
        "type": "string"
      },
      "green_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": [
      "agent_osin_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "user_llm": "openai/gpt-4o-mini",
          "num_tasks": 3,
          "max_steps": 200
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent_osin"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "deepseek_api_key": "${config.green_deepseek_api_key}",
        "gemini_api_key": "${config.green_gemini_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent_osin": {
      "manifest": "https://raw.githubusercontent.com/Mikhail-Osintsev/purple-tau2-agent/main/amber-manifest.json5",
      "config": {
        "openai_api_key": "${config.agent_osin_openai_api_key}",
        "tau2_agent_llm": "${config.agent_osin_tau2_agent_llm}",
        "tau2_agent_temperature": "${config.agent_osin_tau2_agent_temperature}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent_osin.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent_osin.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cf80f-8938-79c0-a221-4c7eadd43e7e",
      "agent_osin": "019d38e4-cce4-7143-b805-0c12a98eab4b"
    }
  }
}
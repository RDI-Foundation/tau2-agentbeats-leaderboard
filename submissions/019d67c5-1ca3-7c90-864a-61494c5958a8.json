{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "green_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "purple_agent_model": {
        "type": "string",
        "default": "qwen/qwen3.6-plus:free"
      },
      "purple_llm_api_key": {
        "type": "string",
        "secret": true
      },
      "purple_llm_base_url": {
        "type": "string",
        "default": "https://openrouter.ai/api/v1"
      }
    },
    "required": [
      "purple_llm_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "user_llm": "qwen/qwen3.6-plus:free",
          "max_steps": 50,
          "AGENT_LLM": "qwen/qwen3.6-plus:free"
        },
        "participant_roles": {
          "green": "green",
          "purple1": "purple"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "deepseek_api_key": "${config.green_deepseek_api_key}",
        "gemini_api_key": "${config.green_gemini_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "purple": {
      "manifest": "https://raw.githubusercontent.com/NickoJo/AB-tau2-purple-agent/refs/heads/main/amber-manifest.json5",
      "config": {
        "agent_model": "${config.purple_agent_model}",
        "llm_api_key": "${config.purple_llm_api_key}",
        "llm_base_url": "${config.purple_llm_base_url}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#purple.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cf80f-8938-79c0-a221-4c7eadd43e7e",
      "purple": "019d6796-2e23-79b1-984d-f00e7858e862"
    }
  }
}
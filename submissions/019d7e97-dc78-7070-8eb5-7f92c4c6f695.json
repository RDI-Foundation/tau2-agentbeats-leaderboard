{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_purple_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "green_deepseek_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "green_openai_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      }
    },
    "required": [
      "agent_purple_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "domain": "airline",
          "user_llm": "openai/gpt-4o-mini",
          "max_steps": 20
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent_purple"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}",
          "purple1": "${bindings.purple1-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/tau2-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "deepseek_api_key": "${config.green_deepseek_api_key}",
        "gemini_api_key": "${config.green_gemini_api_key}",
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent_purple": {
      "manifest": "https://github.com/AlexeyVorobyev/agent_track_tau2/raw/refs/heads/main/amber-manifest.json5",
      "config": {
        "openai_api_key": "${config.agent_purple_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent_purple.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    },
    {
      "to": "#agent_purple.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "purple1-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019cf80f-8938-79c0-a221-4c7eadd43e7e",
      "agent_purple": "019d7e45-3b59-7073-a8bf-a85476d0b43b"
    }
  }
}